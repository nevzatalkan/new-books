# Goodreads Digest — Ortam Değişkenleri Şablonu
# Bu dosyayı kopyalayıp ".env" olarak kaydedin ve değerleri doldurun.
# .env dosyasını asla Git'e commit etmeyin!

# Goodreads RSS feed URL'si
# Profilinize gidin → "RSS" linkine sağ tıklayın → URL'yi kopyalayın
# Örnek: https://www.goodreads.com/user/updates_rss/12345678
GOODREADS_RSS_URL=https://www.goodreads.com/user/updates_rss/<your_user_id>

# Gönderici Gmail adresi
GMAIL_USER=you@gmail.com

# Gmail App Password (hesap şifreniz DEĞİL)
# Oluşturma: Google Hesabım → Güvenlik → 2 Adımlı Doğrulama → Uygulama Şifreleri
# Şifre 16 karakter olacak, boşluksuz girin
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Alıcı e-posta adresi (birden fazla için virgülle ayırın)
TO_EMAIL=recipient@example.com
